# Optional external API for project-internal AI automation.
# Codex automation is separate and does not use these keys.
# Copy this file to .env.local, uncomment one provider block, fill in your own key,
# then restart `npm run dev`. Never commit .env.local.

# Public deployment protection.
# Localhost can run without auth. Any non-local host requires either Basic Auth
# or an API token. Set these before deploying the app publicly.
# ARTIST_STUDIO_AUTH_USER=artist
# ARTIST_STUDIO_AUTH_PASSWORD=change_this_password
# ARTIST_STUDIO_API_TOKEN=change_this_long_random_token

# Optional resource limits for uploaded source materials.
# ARTIST_STUDIO_MAX_UPLOAD_MB=50
# ARTIST_STUDIO_MAX_UPLOAD_TOTAL_MB=100
# ARTIST_STUDIO_MAX_EXTRACTION_MB=50
# ARTIST_STUDIO_MAX_IMAGE_PIXELS=100000000
# ARTIST_STUDIO_MULTIMODAL_MAX_IMAGE_MB=8

# Optional opportunity page fetch limits.
# These only apply to public https opportunity links added by the user.
# SSRF protections for localhost, private networks, and internal DNS remain enforced.
# ARTIST_STUDIO_RENDER_JS_OPPORTUNITY_PAGES=true
# ARTIST_STUDIO_MAX_OPPORTUNITY_PAGES=100
# ARTIST_STUDIO_OPPORTUNITY_MAX_ATTACHMENTS=6
# ARTIST_STUDIO_OPPORTUNITY_MAX_MB=5
# ARTIST_STUDIO_OPPORTUNITY_TEXT_LIMIT=60000
# ARTIST_STUDIO_OPPORTUNITY_PROMPT_TEXT_LIMIT=12000
# ARTIST_STUDIO_OPPORTUNITY_TIMEOUT_MS=30000
# ARTIST_STUDIO_OPPORTUNITY_MAX_REDIRECTS=8
# ARTIST_STUDIO_OPPORTUNITY_FETCH_CONCURRENCY=4

# Optional public opportunity discovery sources.
# Comma-separated https URLs for open-call/residency/grant source pages.
# ARTIST_STUDIO_DISCOVERY_SOURCE_URLS=https://www.artconnect.com/opportunities,https://resartis.org/open-calls/
# ARTIST_STUDIO_DISCOVERY_SOURCES=8
# ARTIST_STUDIO_DISCOVERY_LINKS=80
# ARTIST_STUDIO_DISCOVERY_TIMEOUT_MS=15000
# ARTIST_STUDIO_DISCOVERY_CONCURRENCY=3

# Automation run mode.
# real writes real application records. test/mock write isolated generated folders
# and must not create real ready/submitted application state.
# ARTIST_STUDIO_RUN_MODE=real

# OpenAI-compatible endpoint, including many third-party or self-hosted gateways.
# Use this block when your provider exposes /chat/completions.
# ARTIST_STUDIO_AI_API_KEY=your_key
# ARTIST_STUDIO_AI_PROVIDER=openai-compatible
# ARTIST_STUDIO_AI_BASE_URL=https://your-provider.example.com/v1
# ARTIST_STUDIO_AI_MODEL=your-model-name

# DeepSeek
# DEEPSEEK_API_KEY=your_key
# ARTIST_STUDIO_AI_PROVIDER=deepseek
# ARTIST_STUDIO_AI_MODEL=your-deepseek-model

# OpenAI
# OPENAI_API_KEY=your_key
# ARTIST_STUDIO_AI_PROVIDER=openai
# ARTIST_STUDIO_AI_MODEL=gpt-4o-mini

# Gemini
# GEMINI_API_KEY=your_key
# ARTIST_STUDIO_AI_PROVIDER=gemini
# ARTIST_STUDIO_AI_MODEL=gemini-1.5-pro

# Claude
# ANTHROPIC_API_KEY=your_key
# ARTIST_STUDIO_AI_PROVIDER=claude
# ARTIST_STUDIO_AI_MODEL=claude-3-5-sonnet-latest
