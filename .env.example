# Optional external API for project-internal AI automation.
# Codex automation is separate and does not use these keys.
# Copy this file to .env.local, uncomment one provider block, fill in your own key,
# then restart `npm run dev`. Never commit .env.local.

# OpenAI-compatible endpoint, including many third-party or self-hosted gateways.
# Use this block when your provider exposes /chat/completions.
# ARTIST_STUDIO_AI_API_KEY=your_key
# ARTIST_STUDIO_AI_PROVIDER=openai-compatible
# ARTIST_STUDIO_AI_BASE_URL=https://your-provider.example.com/v1
# ARTIST_STUDIO_AI_MODEL=your-model-name

# DeepSeek
# DEEPSEEK_API_KEY=your_key
# ARTIST_STUDIO_AI_PROVIDER=deepseek
# ARTIST_STUDIO_AI_MODEL=your-deepseek-model

# OpenAI
# OPENAI_API_KEY=your_key
# ARTIST_STUDIO_AI_PROVIDER=openai
# ARTIST_STUDIO_AI_MODEL=gpt-4o-mini

# Gemini
# GEMINI_API_KEY=your_key
# ARTIST_STUDIO_AI_PROVIDER=gemini
# ARTIST_STUDIO_AI_MODEL=gemini-1.5-pro

# Claude
# ANTHROPIC_API_KEY=your_key
# ARTIST_STUDIO_AI_PROVIDER=claude
# ARTIST_STUDIO_AI_MODEL=claude-3-5-sonnet-latest
